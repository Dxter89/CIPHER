# Copy this file to .env and fill in your own values.

# --- Talking robot device (onboard LLM, e.g. DeepSeek) -------------------
# CIPHER talks to your robot over its local HTTP API (Wi-Fi / Tailscale).
# Set the base URL to connect it; leave blank to run CIPHER in offline mode.
# CIPHER_ROBOT_URL=http://100.64.0.5:8080      # your robot's address (a Tailscale IP works)
# CIPHER_ROBOT_TOKEN=                          # bearer token, if the device needs one

# Override these only if your device names its API differently:
# CIPHER_ROBOT_CHAT_PATH=/api/chat
# CIPHER_ROBOT_SAY_PATH=/api/say
# CIPHER_ROBOT_MESSAGE_FIELD=message
# CIPHER_ROBOT_SYSTEM_FIELD=system
# CIPHER_ROBOT_REPLY_FIELD=reply
# CIPHER_ROBOT_TEXT_FIELD=text
# CIPHER_ROBOT_TIMEOUT=30

# --- State & persona file locations (optional overrides) -----------------
# CIPHER_STATE=~/.cipher/state.json
# CIPHER_PERSONA=~/.cipher/persona.json

# --- Reserved for future cloud integrations ------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
